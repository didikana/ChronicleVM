module bench_plugin
cap log.print@1(any...) -> nil "emit audit line"
cap clock.now@1() -> i64 "timestamp plugin execution"
cap random.u64@1() -> i64 "generate deterministic request id"

fn main
  let started = "plugin started"
  cap log.print@1(started)
  let now = cap clock.now@1()
  let request = cap random.u64@1()
  let result = [now, request]
  return result
end
